              const data = inputs.json.value;


              // safer check

              const hasTo = data && data.toLocationDisambiguation && data.toLocationDisambiguation.disambiguationOptions;

              const hasFrom = data && data.fromLocationDisambiguation && data.fromLocationDisambiguation.disambiguationOptions;


              if (hasTo || hasFrom) {

                const toOption = data.toLocationDisambiguation?.disambiguationOptions?.[0];
                const fromOption = data.fromLocationDisambiguation?.disambiguationOptions?.[0];

