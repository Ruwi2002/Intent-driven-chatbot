        '[tBX3vjy3bKOno1Pux15qY]:code "Tube Status API URL"':
          data:
            allowConsole: false
            allowFetch: false
            allowProcess: false
            allowRequire: false
            allowRivet: false
            body: ""
            code: >-
              const text = String(inputs.line_status.value || "").toLowerCase();


              const lines = [
                "bakerloo","central","circle","district",
                "hammersmith-city","jubilee","metropolitan",
                "northern","piccadilly","victoria","waterloo-city"
              ];


              const lineMap = {
                "hammersmith and city": "hammersmith-city",
                "waterloo and city": "waterloo-city"
              };


              let normalized = text.replace(/&/g, "and");


              // check mapped names first

              let found = Object.keys(lineMap).find(k => normalized.includes(k));


              if (found) {
                found = lineMap[found];
              } else {
                found = lines.find(l => normalized.includes(l));
              }


              return {
                lineId: {
                  type: "string",
                  value: `https://api.tfl.gov.uk/Line/${found}/Status` || "all"
                }
              };
            inputNames:
              - line_status
            outputNames:
              - lineId
