        '[08-SZoCCps83l3h9fQSx3]:code "Arrival Response"':
          data:
            allowConsole: false
            allowFetch: false
            allowProcess: false
            allowRequire: false
            allowRivet: false
            body: ""
            code: |-
              const data = inputs.json.value;

              if (!data || data.length === 0) {
                return {
                  output1: {
                    type: "string",
                    value: "No upcoming trains."
                  }
                };
              }

              // sort by arrival time
              data.sort((a, b) => a.timeToStation - b.timeToStation);

              // top 3 trains
              const result = data.slice(0, 3).map(train => {
                const line = train.lineName;
                const destination = train.destinationName;
                const time = Math.round(train.timeToStation / 60);

                return `${line} → ${destination} in ${time} min`;
              }).join("\n");

              return {
                output1: {
                  type: "string",
                  value: result
                }
              };
            inputNames:
              - json
            outputNames: output1
          visualData: 2158.857866525435/-502.57904923226226/418.2488556778544/206//
        '[45Ajmk7Z24ohfTjK62A_D]:code "journey Response"':
          data:
            allowConsole: false
            allowFetch: false
            allowProcess: false
            allowRequire: false
            allowRivet: false
            body: ""
            code: >-
              const data = inputs.json.value;


              const journeys = data.journeys;


              if (!journeys || journeys.length === 0) {
                return {
                  output1: {
                    type: "string",
                    value: "No journey found."
                  }
                };
              }


              // first journey

              const j = journeys[0];


              // only tube legs

              const tubeLegs = j.legs.filter(l => l.mode.name === "tube");


              if (tubeLegs.length === 0) {
                return {
                  output1: {
                    type: "string",
                    value: "No tube route available."
                  }
                };
              }


              // sum duration

              const tubeDuration = tubeLegs.reduce((sum, leg) => sum + leg.duration, 0);


              return {
                output1: {
                  type: "string",
                  value: `Tube travel time: ${tubeDuration} min`
                }
              };
            headers: ""
            inputNames:
              - json
            outputNames: output1
          visualData: 2152.5925231751244/-28.71098489749994/432.3589734367288/211//
